# -------------------------
# Flask / Server
# -------------------------
# Flask environment: development, testing, or production
FLASK_ENV=development

# Port your Flask app will run on
PORT=4000

# -------------------------
# Database (PostgreSQL)
# -------------------------
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Replace USER and PASSWORD with your local PostgreSQL credentials
DATABASE_URL=postgres://db_user:db_password@localhost:5432/creditcare_dev

# -------------------------
# JWT Authentication
# -------------------------
# Generate strong random secrets (at least 32 chars, alphanumeric + symbols)
# Example: use `openssl rand -hex 32` or `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET=example_jwt_secret_32chars_minimum
JWT_REFRESH_SECRET=example_refresh_secret_32chars_minimum

# Token expiration times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------
# Email / SMTP (for reminders)
# -------------------------
# Replace with your SMTP provider details
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Default "from" address for outgoing emails
EMAIL_FROM="CreditCare <no-reply@example.com>"

# -------------------------
# Frontend URL
# -------------------------
# Local frontend dev server
FRONTEND_URL=http://localhost:3000

# -------------------------
# Worker / Queue (optional)
# -------------------------
# Redis connection string for background tasks (Celery, RQ, etc.)
REDIS_URL=redis://localhost:6379

# -------------------------
# Observability
# -------------------------
# Sentry DSN for error monitoring (leave empty if unused locally)
SENTRY_DSN=

# -------------------------
# App Defaults
# -------------------------
# Default timezone and currency for the app
DEFAULT_TIMEZONE=America/Mexico_City
DEFAULT_CURRENCY=MXN

# -------------------------
# Security / Rate Limits
# -------------------------
# Rate limiting settings (per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
